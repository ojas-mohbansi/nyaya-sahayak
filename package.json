{
  "name": "@workspace/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN npx expo start --localhost --port 8081",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "node scripts/bump-version.mjs",
    "release:patch": "node scripts/bump-version.mjs patch",
    "release:minor": "node scripts/bump-version.mjs minor",
    "release:major": "node scripts/bump-version.mjs major",
    "build:apk:local": "eas build -p android --profile production-apk --local --output ./build/nyaya-sahayak.apk",
    "build:apk:cloud": "eas build -p android --profile production-apk --non-interactive --no-wait",
    "build:apk:both": "npm run build:apk:cloud && npm run build:apk:local",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo/cli": "55.0.26",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@ungap/structured-clone": "^1.3.0",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "expo": "~54.0.27",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "dependencies": {
    "expo-clipboard": "^55.0.13",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-network": "^55.0.13",
    "expo-notifications": "~55.0.20",
    "expo-sharing": "~55.0.18",
    "expo-speech": "~55.0.13",
    "expo-speech-recognition": "^3.1.2",
    "expo-sqlite": "~55.0.15",
    "react-native-webview": "13.15.0"
  }
